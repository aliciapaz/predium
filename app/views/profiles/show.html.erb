<% content_for(:title, t("nav.profile")) %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold text-earth-900"><%= t("titles.profile_show") %></h1>
    <%= link_to t("buttons.edit"), edit_profile_path,
        class: "inline-flex items-center px-4 py-2 bg-forest-600 text-white text-sm font-medium rounded-md hover:bg-forest-700 transition-colors" %>
  </div>

  <%# User info card %>
  <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
    <h2 class="text-sm font-semibold text-earth-500 uppercase tracking-wide mb-4"><%= t("labels.user_info") %></h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.name") %></dt>
        <dd class="mt-1 text-sm text-earth-900 font-medium"><%= current_user.first_name %> <%= current_user.last_name %></dd>
      </div>
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.email") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= current_user.email %></dd>
      </div>
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.locale") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= current_user.locale == "es" ? "Espa\u00f1ol" : "English" %></dd>
      </div>
    </dl>
  </div>

  <%# Profile info card %>
  <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
    <h2 class="text-sm font-semibold text-earth-500 uppercase tracking-wide mb-4"><%= t("labels.profile_info") %></h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.phone") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= @profile.phone.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.professional_role") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= @profile.role_name.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.country") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= @profile.country.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.region") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= @profile.region.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm text-earth-500"><%= t("labels.locality") %></dt>
        <dd class="mt-1 text-sm text-earth-900"><%= @profile.locality.presence || "—" %></dd>
      </div>
    </dl>
  </div>

  <%# Organization memberships card %>
  <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
    <h2 class="text-sm font-semibold text-earth-500 uppercase tracking-wide mb-4"><%= t("navigation.organizations") %></h2>
    <% memberships = current_user.memberships.includes(:organization) %>
    <% if memberships.any? %>
      <ul class="divide-y divide-earth-100">
        <% memberships.each do |membership| %>
          <li class="py-3 flex items-center justify-between">
            <div>
              <%= link_to membership.organization.name, organization_forms_path(membership.organization),
                  class: "text-sm font-medium text-forest-700 hover:text-forest-800" %>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= membership.admin? ? 'bg-forest-100 text-forest-800' : 'bg-earth-100 text-earth-700' %>">
              <%= t("roles.#{membership.role}") %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-earth-400"><%= t("common.no_results") %></p>
    <% end %>
  </div>
</div>
