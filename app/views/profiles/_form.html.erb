<%= form_with(model: profile, url: profile_path, method: :patch) do |f| %>
  <div class="space-y-4">
    <div>
      <%= f.label :phone, t("labels.phone"), class: "block text-sm font-medium text-earth-700 mb-1" %>
      <%= f.text_field :phone, autocomplete: "tel",
          class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
    </div>

    <div>
      <%= f.label :role_name, t("labels.professional_role"), class: "block text-sm font-medium text-earth-700 mb-1" %>
      <%= f.text_field :role_name,
          class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
    </div>

    <div>
      <%= f.label :country, t("labels.country"), class: "block text-sm font-medium text-earth-700 mb-1" %>
      <%= f.text_field :country, autocomplete: "country-name",
          class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :region, t("labels.region"), class: "block text-sm font-medium text-earth-700 mb-1" %>
        <%= f.text_field :region,
            class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
      </div>
      <div>
        <%= f.label :locality, t("labels.locality"), class: "block text-sm font-medium text-earth-700 mb-1" %>
        <%= f.text_field :locality,
            class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
      </div>
    </div>

    <%# Locale selector (on the user model, not profile) %>
    <div>
      <label for="user_locale" class="block text-sm font-medium text-earth-700 mb-1"><%= t("labels.locale") %></label>
      <select id="user_locale" name="user[locale]"
              class="w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500">
        <option value="en" <%= "selected" if current_user.locale == "en" %>>English</option>
        <option value="es" <%= "selected" if current_user.locale == "es" %>>Espa&#241;ol</option>
      </select>
    </div>

    <div class="flex items-center justify-between pt-2">
      <%= link_to t("buttons.cancel"), profile_path,
          class: "text-sm text-earth-500 hover:text-earth-700 transition-colors" %>
      <%= f.submit t("buttons.save"),
          class: "bg-forest-600 text-white py-2 px-6 rounded-md text-sm font-medium hover:bg-forest-700 transition-colors cursor-pointer" %>
    </div>
  </div>
<% end %>
