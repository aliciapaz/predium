<% content_for(:title, t("titles.forms_index")) %>

<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-earth-900"><%= t("titles.forms_index") %></h1>
  <%= link_to new_form_path,
      class: "inline-flex items-center gap-2 px-5 py-2.5 bg-forest-600 text-white font-medium rounded-lg hover:bg-forest-700 transition-colors shadow-sm" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    <%= t("questionnaire.new_questionnaire") %>
  <% end %>
</div>

<%# Drafts Section %>
<section class="mb-10">
  <div class="flex items-center gap-2 mb-4">
    <h2 class="text-lg font-semibold text-earth-800"><%= t("forms.drafts") %></h2>
    <span class="inline-flex items-center justify-center px-2 py-0.5 text-xs font-medium rounded-full bg-mustard-100 text-mustard-700">
      <%= @drafts.size %>
    </span>
  </div>

  <% if @drafts.any? %>
    <div class="space-y-3">
      <% @drafts.each do |form| %>
        <%= render "forms/form_card", form: form %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
        message: t("forms.no_drafts"),
        action_text: t("questionnaire.new_questionnaire"),
        action_path: new_form_path %>
  <% end %>
</section>

<%# Completed Section %>
<section>
  <div class="flex items-center gap-2 mb-4">
    <h2 class="text-lg font-semibold text-earth-800"><%= t("forms.completed") %></h2>
    <span class="inline-flex items-center justify-center px-2 py-0.5 text-xs font-medium rounded-full bg-forest-100 text-forest-700">
      <%= @completed.size %>
    </span>
  </div>

  <% if @completed.any? %>
    <div class="space-y-3">
      <% @completed.each do |form| %>
        <%= render "forms/form_card", form: form %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", message: t("forms.no_completed") %>
  <% end %>
</section>
