<% content_for(:title, t("titles.form_new")) %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to forms_path, class: "text-sm text-earth-500 hover:text-earth-700 inline-flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t("forms.back_to_forms") %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-earth-900 mb-6"><%= t("titles.form_new") %></h1>

  <%= render "farm_info_form", form: @form, submit_label: t("forms.create_and_start") %>
</div>
