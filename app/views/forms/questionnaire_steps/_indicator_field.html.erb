<%
  current_value = response&.value
  ind_key = indicator[:key]
  i18n_base = indicator[:i18n_key]
%>

<div class="bg-white border border-earth-200 rounded-lg p-5" data-controller="question">
  <%# Indicator name and info toggle %>
  <div class="flex items-start justify-between mb-4">
    <h3 class="text-base font-semibold text-earth-900"><%= t("#{i18n_base}.name") %></h3>
    <div class="relative shrink-0 ml-2" data-controller="collapsible">
      <button type="button" data-action="collapsible#toggle"
              class="text-earth-400 hover:text-earth-600 p-1">
        <svg data-collapsible-target="icon" class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </button>
      <div data-collapsible-target="content" class="hidden absolute right-0 mt-2 w-80 bg-white border border-earth-200 rounded-lg shadow-lg p-4 z-10 text-left">
        <p class="text-sm text-earth-600 mb-3"><%= t("#{i18n_base}.description") %></p>
        <div class="space-y-2 text-xs">
          <div class="flex gap-2">
            <span class="inline-flex items-center px-1.5 py-0.5 rounded bg-rose-100 text-rose-700 font-medium shrink-0">1-3</span>
            <span class="text-earth-600"><%= t("#{i18n_base}.scoring.low") %></span>
          </div>
          <div class="flex gap-2">
            <span class="inline-flex items-center px-1.5 py-0.5 rounded bg-mustard-100 text-mustard-700 font-medium shrink-0">4-7</span>
            <span class="text-earth-600"><%= t("#{i18n_base}.scoring.medium") %></span>
          </div>
          <div class="flex gap-2">
            <span class="inline-flex items-center px-1.5 py-0.5 rounded bg-forest-100 text-forest-700 font-medium shrink-0">8-10</span>
            <span class="text-earth-600"><%= t("#{i18n_base}.scoring.high") %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Hidden input for the actual value %>
  <input type="hidden"
         name="form_responses[<%= ind_key %>]"
         value="<%= current_value %>"
         data-question-target="hiddenInput">

  <%# 1-10 Scoring Grid (5 cols x 2 rows) %>
  <div class="grid grid-cols-5 sm:gap-2 gap-1.5">
    <% (1..10).each do |n| %>
      <%
        selected = current_value == n
        if selected
          if n <= 3
            btn_class = "bg-rose-100 border-rose-500 text-rose-700 ring-2 ring-rose-300"
          elsif n <= 7
            btn_class = "bg-mustard-100 border-mustard-500 text-mustard-700 ring-2 ring-mustard-300"
          else
            btn_class = "bg-forest-100 border-forest-500 text-forest-700 ring-2 ring-forest-300"
          end
        else
          btn_class = "bg-earth-50 border-earth-300 text-earth-600 hover:bg-earth-100"
        end
      %>
      <button type="button"
              data-question-target="optionBtn"
              data-action="question#select"
              data-value="<%= n %>"
              class="aspect-square min-h-[44px] flex items-center justify-center border-2 rounded-lg text-sm font-semibold transition-all cursor-pointer <%= btn_class %>">
        <%= n %>
      </button>
    <% end %>
  </div>

  <%# Score range descriptions — always visible, highlighted on selection %>
  <div class="mt-3 space-y-1.5 text-sm">
    <div data-question-target="descLow"
         class="p-2.5 rounded-lg border transition-all <%= current_value.present? && current_value <= 3 ? 'bg-rose-50 border-rose-300 text-rose-700 ring-2 ring-rose-200' : current_value.present? ? 'bg-earth-50 border-earth-100 text-earth-400' : 'bg-rose-50/50 border-rose-100 text-rose-600/80' %>">
      <span class="font-medium">1-3:</span> <%= t("#{i18n_base}.scoring.low") %>
    </div>
    <div data-question-target="descMedium"
         class="p-2.5 rounded-lg border transition-all <%= current_value.present? && current_value >= 4 && current_value <= 7 ? 'bg-mustard-50 border-mustard-300 text-mustard-700 ring-2 ring-mustard-200' : current_value.present? ? 'bg-earth-50 border-earth-100 text-earth-400' : 'bg-mustard-50/50 border-mustard-100 text-mustard-600/80' %>">
      <span class="font-medium">4-7:</span> <%= t("#{i18n_base}.scoring.medium") %>
    </div>
    <div data-question-target="descHigh"
         class="p-2.5 rounded-lg border transition-all <%= current_value.present? && current_value >= 8 ? 'bg-forest-50 border-forest-300 text-forest-700 ring-2 ring-forest-200' : current_value.present? ? 'bg-earth-50 border-earth-100 text-earth-400' : 'bg-forest-50/50 border-forest-100 text-forest-600/80' %>">
      <span class="font-medium">8-10:</span> <%= t("#{i18n_base}.scoring.high") %>
    </div>
  </div>
</div>
