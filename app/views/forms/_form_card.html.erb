<%= turbo_frame_tag dom_id(form) do %>
  <div class="bg-white border border-earth-200 rounded-lg p-5 hover:shadow-md transition-shadow">
    <div class="flex items-start justify-between">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-1">
          <h3 class="font-semibold text-earth-900 truncate"><%= form.name %></h3>
          <% if form.draft? %>
            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-mustard-100 text-mustard-700">
              <%= t("states.draft") %>
            </span>
          <% else %>
            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-forest-100 text-forest-700">
              <%= t("states.completed") %>
            </span>
          <% end %>
        </div>

        <p class="text-sm text-earth-500">
          <% if form.country.present? || form.region.present? %>
            <%= [form.region, form.country].compact.join(", ") %>
            &middot;
          <% end %>
          <%= l(form.updated_at, format: :short) rescue form.updated_at.strftime("%b %d, %Y") %>
        </p>

        <% if form.draft? %>
          <% total = QuestionnaireConfig.core_indicators.size %>
          <% scored = form.form_responses.core.count %>
          <% pct = total.positive? ? (scored * 100.0 / total).round : 0 %>
          <div class="mt-3 flex items-center gap-3">
            <div class="flex-1 bg-earth-100 rounded-full h-1.5 max-w-xs">
              <div class="bg-forest-500 h-1.5 rounded-full transition-all" style="width: <%= pct %>%"></div>
            </div>
            <span class="text-xs text-earth-500 whitespace-nowrap"><%= t("questionnaire.indicators_count", answered: scored, total: total) %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-4 mt-4 pt-3 border-t border-earth-100">
      <% if form.draft? %>
        <% first_dim = QuestionnaireConfig.dimensions.first %>
        <%= link_to t("questionnaire.continue"),
            form_questionnaire_step_path(form, first_dim[:key]),
            data: { turbo_frame: "_top" },
            class: "text-sm font-medium text-forest-600 hover:text-forest-700" %>
        <%= link_to t("forms.edit_farm_info"),
            edit_form_path(form),
            data: { turbo_frame: "_top" },
            class: "text-sm text-earth-500 hover:text-earth-700" %>
      <% else %>
        <%= link_to t("forms.view_results"),
            form_path(form),
            data: { turbo_frame: "_top" },
            class: "text-sm font-medium text-forest-600 hover:text-forest-700" %>
      <% end %>

      <%= button_to t("buttons.delete"),
          form_path(form),
          method: :delete,
          form: { data: { turbo_confirm: t("common.confirm_delete") } },
          class: "text-sm text-rose-500 hover:text-rose-700 ml-auto" %>
    </div>
  </div>
<% end %>
