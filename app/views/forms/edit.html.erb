<% content_for(:title, t("titles.form_edit")) %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <%= link_to forms_path, class: "text-sm text-earth-500 hover:text-earth-700 inline-flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t("forms.back_to_forms") %>
    <% end %>

    <% if @form.draft? %>
      <% first_dim = QuestionnaireConfig.dimensions.first %>
      <%= link_to form_questionnaire_step_path(@form, first_dim[:key]),
          class: "text-sm font-medium text-forest-600 hover:text-forest-700 inline-flex items-center gap-1" do %>
        <%= t("questionnaire.continue") %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-earth-900 mb-6"><%= t("titles.form_edit") %></h1>

  <%= render "farm_info_form", form: @form, submit_label: t("farm_info.update_farm_info") %>
</div>
