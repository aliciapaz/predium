<% content_for(:title, "#{t('navigation.members')} — #{@organization.name}") %>

<% current_membership = current_user.memberships.find_by(organization: @organization) %>
<% is_admin = current_membership&.admin? %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <h1 class="text-xl font-bold text-earth-900"><%= t("navigation.members") %> &mdash; <%= @organization.name %></h1>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-earth-100 text-earth-700">
        <%= @memberships.size %>
      </span>
    </div>
    <% if is_admin %>
      <%= link_to t("labels.invite_member"), new_organization_invitation_path(@organization),
          class: "inline-flex items-center px-4 py-2 bg-forest-600 text-white text-sm font-medium rounded-md hover:bg-forest-700 transition-colors" %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-earth-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-earth-200">
        <thead class="bg-earth-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-earth-500 uppercase tracking-wide"><%= t("labels.name") %></th>
            <th class="px-4 py-3 text-left text-xs font-medium text-earth-500 uppercase tracking-wide"><%= t("labels.email") %></th>
            <th class="px-4 py-3 text-left text-xs font-medium text-earth-500 uppercase tracking-wide"><%= t("labels.role") %></th>
            <th class="px-4 py-3 text-left text-xs font-medium text-earth-500 uppercase tracking-wide"><%= t("labels.joined") %></th>
            <% if is_admin %>
              <th class="px-4 py-3 text-right text-xs font-medium text-earth-500 uppercase tracking-wide"><%= t("labels.actions") %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-earth-100">
          <% @memberships.each do |membership| %>
            <tr class="hover:bg-earth-50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-earth-900"><%= membership.user.first_name %> <%= membership.user.last_name %></td>
              <td class="px-4 py-3 text-sm text-earth-600"><%= membership.user.email %></td>
              <td class="px-4 py-3">
                <% role_class = membership.admin? ? "bg-forest-100 text-forest-800" : "bg-earth-100 text-earth-700" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= role_class %>">
                  <%= t("roles.#{membership.role}") %>
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-earth-500"><%= membership.created_at.strftime("%b %d, %Y") %></td>
              <% if is_admin %>
                <td class="px-4 py-3 text-right">
                  <% unless membership.user == current_user %>
                    <%= button_to t("labels.remove"),
                        organization_membership_path(@organization, membership),
                        method: :delete,
                        data: { turbo_confirm: t("common.confirm_delete") },
                        class: "text-sm text-rose-600 hover:text-rose-800 transition-colors cursor-pointer" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
