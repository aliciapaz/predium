<% content_for(:page_title, t("admin.users")) %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-earth-900">
      <%= t("admin.users") %>
      <span class="ml-2 text-sm font-normal text-earth-500">(<%= @users.size %>)</span>
    </h1>
  </div>

  <!-- Search -->
  <%= form_with url: admin_users_path, method: :get, class: "bg-white rounded-lg shadow-sm border border-earth-200 p-4" do %>
    <div class="flex items-end gap-4">
      <div class="flex-1">
        <label class="block text-sm font-medium text-earth-700 mb-1"><%= t("admin.search_users") %></label>
        <input type="text" name="q" value="<%= params[:q] %>"
               placeholder="<%= t("admin.search_placeholder") %>"
               class="w-full rounded-lg border-earth-300 text-sm focus:ring-forest-500 focus:border-forest-500">
      </div>
      <button type="submit" class="bg-forest-500 hover:bg-forest-600 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors">
        <%= t("admin.search") %>
      </button>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow-sm border border-earth-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-earth-100">
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_name") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_email") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_role") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_organizations") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_forms") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_joined") %></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr class="hover:bg-earth-50 transition-colors">
              <td class="px-6 py-3 border-b border-earth-100">
                <%= link_to "#{user.first_name} #{user.last_name}", admin_user_path(user),
                    class: "text-forest-600 hover:text-forest-800 font-medium" %>
              </td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= user.email %></td>
              <td class="px-6 py-3 border-b border-earth-100"><%= role_badge(user.platform_role) %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= user.organizations.size %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= user.forms.size %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= format_admin_date(user.created_at) %></td>
            </tr>
          <% end %>
          <% if @users.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-sm text-earth-500"><%= t("admin.no_users") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
