<% content_for(:page_title, "#{@user.first_name} #{@user.last_name}") %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-earth-900"><%= @user.first_name %> <%= @user.last_name %></h1>
      <p class="text-sm text-earth-600 mt-1"><%= @user.email %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= role_badge(@user.platform_role) %>
      <%= link_to t("admin.edit_role"), edit_admin_user_path(@user),
          class: "text-sm text-forest-600 hover:text-forest-800" %>
    </div>
  </div>

  <!-- Profile Info -->
  <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
    <h2 class="text-lg font-semibold text-earth-900 mb-4"><%= t("admin.profile") %></h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <dt class="text-xs font-medium text-earth-500 uppercase"><%= t("admin.phone") %></dt>
        <dd class="text-sm text-earth-900 mt-1"><%= @user.profile&.phone || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-earth-500 uppercase"><%= t("admin.professional_role") %></dt>
        <dd class="text-sm text-earth-900 mt-1"><%= @user.profile&.role_name || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-earth-500 uppercase"><%= t("admin.table_country") %></dt>
        <dd class="text-sm text-earth-900 mt-1"><%= @user.profile&.country || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-earth-500 uppercase"><%= t("admin.table_region") %></dt>
        <dd class="text-sm text-earth-900 mt-1"><%= @user.profile&.region || "—" %></dd>
      </div>
    </dl>
  </div>

  <!-- Organizations -->
  <div class="bg-white rounded-lg shadow-sm border border-earth-200">
    <div class="px-6 py-4 border-b border-earth-200">
      <h2 class="text-lg font-semibold text-earth-900"><%= t("admin.organizations") %></h2>
    </div>
    <% if @memberships.any? %>
      <ul class="divide-y divide-earth-100">
        <% @memberships.each do |membership| %>
          <li class="px-6 py-3 flex items-center justify-between">
            <span class="text-sm font-medium text-earth-900"><%= membership.organization.name %></span>
            <%= role_badge(membership.role) %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="px-6 py-8 text-center text-sm text-earth-500"><%= t("admin.no_organizations") %></p>
    <% end %>
  </div>

  <!-- Recent Forms -->
  <div class="bg-white rounded-lg shadow-sm border border-earth-200">
    <div class="px-6 py-4 border-b border-earth-200">
      <h2 class="text-lg font-semibold text-earth-900"><%= t("admin.recent_forms") %></h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-earth-100">
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_farm_name") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_state") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_country") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_created") %></th>
          </tr>
        </thead>
        <tbody>
          <% @recent_forms.each do |form| %>
            <tr class="hover:bg-earth-50 transition-colors">
              <td class="px-6 py-3 border-b border-earth-100">
                <%= link_to form.name, form_path(form), class: "text-forest-600 hover:text-forest-800 font-medium" %>
              </td>
              <td class="px-6 py-3 border-b border-earth-100">
                <% state_classes = form.completed? ? "bg-forest-100 text-forest-800" : "bg-earth-200 text-earth-700" %>
                <span class="inline-block rounded-full px-2 py-1 text-xs font-medium <%= state_classes %>"><%= form.state.titleize %></span>
              </td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= form.country %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= format_admin_date(form.created_at) %></td>
            </tr>
          <% end %>
          <% if @recent_forms.empty? %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-sm text-earth-500"><%= t("admin.no_forms") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%= link_to t("admin.back_to_users"), admin_users_path, class: "text-sm text-earth-600 hover:text-earth-800" %>
</div>
