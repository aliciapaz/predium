<% content_for(:page_title, t("admin.edit_user_role")) %>

<div class="space-y-6">
  <h1 class="text-2xl font-bold text-earth-900"><%= t("admin.edit_user_role") %> — <%= @user.first_name %> <%= @user.last_name %></h1>

  <div class="max-w-lg mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
      <%= form_with model: [:admin, @user], class: "space-y-4" do |f| %>
        <div>
          <label for="user_platform_role" class="block text-sm font-medium text-earth-700 mb-1"><%= t("admin.platform_role") %></label>
          <%= f.select :platform_role, User.platform_roles.keys.map { |r| [r.titleize, r] },
              {}, class: "w-full rounded-lg border-earth-300 text-sm focus:ring-forest-500 focus:border-forest-500" %>
        </div>

        <p class="text-xs text-mustard-700 bg-mustard-50 border border-mustard-200 rounded-lg p-3">
          <%= t("admin.role_warning") %>
        </p>

        <div class="flex items-center gap-3">
          <%= f.submit t("admin.update_role"),
              class: "bg-forest-500 hover:bg-forest-600 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors cursor-pointer" %>
          <%= link_to t("buttons.cancel"), admin_user_path(@user), class: "text-sm text-earth-600 hover:text-earth-800" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
