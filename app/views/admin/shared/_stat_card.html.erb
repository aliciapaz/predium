<%# locals: (title:, value:, subtitle: nil) %>
<div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6 border-t-4 border-t-forest-500">
  <p class="text-3xl font-bold text-earth-900"><%= value %></p>
  <p class="text-sm text-earth-600 mt-1"><%= title %></p>
  <% if subtitle.present? %>
    <p class="text-xs text-earth-400 mt-1"><%= subtitle %></p>
  <% end %>
</div>
