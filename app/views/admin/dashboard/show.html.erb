<% content_for(:page_title, t("admin.dashboard")) %>

<div class="space-y-6">
  <h1 class="text-2xl font-bold text-earth-900"><%= t("admin.dashboard") %></h1>

  <!-- Stats cards -->
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
    <%= render "admin/shared/stat_card", title: t("admin.total_users"), value: @total_users %>
    <%= render "admin/shared/stat_card", title: t("admin.total_organizations"), value: @total_organizations %>
    <%= render "admin/shared/stat_card", title: t("admin.completed_forms"), value: @completed_forms %>
    <%= render "admin/shared/stat_card", title: t("admin.draft_forms"), value: @draft_forms %>
    <%= render "admin/shared/stat_card", title: t("admin.countries_active"), value: @countries.size %>
  </div>

  <!-- Filter bar -->
  <%= form_with url: admin_root_path, method: :get, class: "bg-white rounded-lg shadow-sm border border-earth-200 p-4" do |f| %>
    <div class="flex flex-wrap items-end gap-4">
      <div>
        <label class="block text-sm font-medium text-earth-700 mb-1"><%= t("admin.filter_country") %></label>
        <select name="country" class="rounded-lg border-earth-300 text-sm focus:ring-forest-500 focus:border-forest-500">
          <option value=""><%= t("admin.filter_all_countries") %></option>
          <% @countries.each do |country| %>
            <option value="<%= country %>" <%= "selected" if params[:country] == country %>><%= country %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-earth-700 mb-1"><%= t("admin.filter_from") %></label>
        <input type="date" name="date_from" value="<%= params[:date_from] %>"
               class="rounded-lg border-earth-300 text-sm focus:ring-forest-500 focus:border-forest-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-earth-700 mb-1"><%= t("admin.filter_to") %></label>
        <input type="date" name="date_to" value="<%= params[:date_to] %>"
               class="rounded-lg border-earth-300 text-sm focus:ring-forest-500 focus:border-forest-500">
      </div>
      <div>
        <button type="submit" class="bg-forest-500 hover:bg-forest-600 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors">
          <%= t("admin.filter_apply") %>
        </button>
      </div>
    </div>
  <% end %>

  <!-- Recent Activity -->
  <div class="bg-white rounded-lg shadow-sm border border-earth-200">
    <div class="px-6 py-4 border-b border-earth-200 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-earth-900"><%= t("admin.recent_activity") %></h2>
      <button disabled class="bg-earth-200 text-earth-500 rounded-lg px-4 py-2 text-sm font-medium cursor-not-allowed">
        <%= t("admin.export_csv") %>
      </button>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-earth-100">
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_farm_name") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_user") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_country") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_region") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_completed") %></th>
          </tr>
        </thead>
        <tbody>
          <% @recent_forms.each do |form| %>
            <tr class="hover:bg-earth-50 transition-colors">
              <td class="px-6 py-3 border-b border-earth-100">
                <%= link_to form.name, form_path(form), class: "text-forest-600 hover:text-forest-800 font-medium" %>
              </td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700">
                <%= form.user.first_name %> <%= form.user.last_name %>
              </td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= form.country %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= form.region %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= format_admin_date(form.completed_at) %></td>
            </tr>
          <% end %>
          <% if @recent_forms.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-sm text-earth-500"><%= t("admin.no_completed_forms") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
