<% content_for(:page_title, t("admin.organizations")) %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-earth-900">
      <%= t("admin.organizations") %>
      <span class="ml-2 text-sm font-normal text-earth-500">(<%= @organizations.size %>)</span>
    </h1>
    <%= link_to t("admin.new_organization"), new_admin_organization_path,
        class: "bg-forest-500 hover:bg-forest-600 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors" %>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-earth-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-earth-100">
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_name") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_members") %></th>
            <th class="text-left text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("admin.table_created") %></th>
            <th class="text-right text-xs font-medium text-earth-700 uppercase tracking-wider px-6 py-3"><%= t("labels.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @organizations.each do |org| %>
            <tr class="hover:bg-earth-50 transition-colors">
              <td class="px-6 py-3 border-b border-earth-100 font-medium text-earth-900"><%= org.name %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= org.members_count %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-sm text-earth-700"><%= format_admin_date(org.created_at) %></td>
              <td class="px-6 py-3 border-b border-earth-100 text-right space-x-3">
                <%= link_to t("admin.view"), admin_organization_path(org), class: "text-sm text-forest-600 hover:text-forest-800" %>
                <%= link_to t("buttons.edit"), edit_admin_organization_path(org), class: "text-sm text-earth-600 hover:text-earth-800" %>
                <%= button_to t("buttons.delete"), admin_organization_path(org), method: :delete,
                    class: "text-sm text-rose-600 hover:text-rose-800",
                    data: { turbo_confirm: t("admin.confirm_delete_org") } %>
              </td>
            </tr>
          <% end %>
          <% if @organizations.empty? %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-sm text-earth-500"><%= t("admin.no_organizations") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
