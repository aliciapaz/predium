<%# locals: (organization:) %>
<div class="max-w-lg mx-auto">
  <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
    <%= form_with model: [:admin, organization], class: "space-y-4" do |f| %>
      <% if organization.errors.any? %>
        <div class="bg-rose-50 text-rose-800 border border-rose-200 rounded-lg p-4">
          <ul class="list-disc list-inside text-sm">
            <% organization.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label for="organization_name" class="block text-sm font-medium text-earth-700 mb-1"><%= t("admin.org_name") %></label>
        <%= f.text_field :name, class: "w-full rounded-lg border-earth-300 text-sm focus:ring-forest-500 focus:border-forest-500",
            placeholder: t("admin.org_name_placeholder") %>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit organization.persisted? ? t("admin.update_organization") : t("admin.create_organization"),
            class: "bg-forest-500 hover:bg-forest-600 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors cursor-pointer" %>
        <%= link_to t("buttons.cancel"), admin_organizations_path, class: "text-sm text-earth-600 hover:text-earth-800" %>
      </div>
    <% end %>
  </div>
</div>
