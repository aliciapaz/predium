<div class="text-center py-12">
  <svg class="mx-auto h-12 w-12 text-earth-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
  </svg>
  <p class="mt-3 text-earth-500 text-sm"><%= message %></p>
  <% if local_assigns[:action_text] && local_assigns[:action_path] %>
    <div class="mt-4">
      <%= link_to action_text, action_path,
          class: "inline-flex items-center px-4 py-2 bg-forest-600 text-white text-sm font-medium rounded-md hover:bg-forest-700 transition-colors" %>
    </div>
  <% end %>
</div>
