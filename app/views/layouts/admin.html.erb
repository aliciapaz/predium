<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Admin - Predium" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-earth-50 text-earth-900 min-h-screen flex" data-controller="admin-sidebar">
    <!-- Overlay backdrop -->
    <div data-admin-sidebar-target="overlay" data-action="click->admin-sidebar#close"
         class="hidden fixed inset-0 bg-black/50 z-30 md:hidden"></div>

    <!-- Sidebar -->
    <aside data-admin-sidebar-target="sidebar"
           class="hidden md:flex w-56 bg-forest-800 text-white min-h-screen flex-col flex-shrink-0 fixed md:static z-40 transition-transform duration-200 -translate-x-full md:translate-x-0">
      <div class="px-4 py-5">
        <h1 class="text-lg font-bold tracking-tight"><%= t("admin.predium_admin") %></h1>
      </div>

      <nav class="flex-1 px-2 space-y-1">
        <%= admin_sidebar_link t("admin.dashboard"), admin_root_path %>
        <%= admin_sidebar_link t("admin.organizations"), admin_organizations_path %>
        <%= admin_sidebar_link t("admin.users"), admin_users_path %>
      </nav>

      <div class="px-4 py-4 border-t border-forest-700">
        <%= link_to t("admin.back_to_app"), root_path, class: "text-sm text-forest-200 hover:text-white transition-colors" %>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 flex flex-col min-h-screen">
      <header class="bg-white border-b border-earth-200 px-6 py-3 flex items-center justify-between">
        <button type="button" data-action="admin-sidebar#toggle" class="md:hidden text-earth-600 hover:text-earth-800 p-1 -ml-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <h2 class="text-sm font-medium text-earth-700"><%= yield :page_title %></h2>
        <span class="text-sm text-earth-500"><%= current_user.first_name %> <%= current_user.last_name %></span>
      </header>

      <%= render "shared/flash" %>

      <main class="flex-1 p-6">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
