<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-forest-700">Predium</h1>
      <p class="mt-1 text-sm text-earth-500"><%= t("devise_views.sign_in_subtitle") %></p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
      <%= form_for(resource, as: resource_name, url: user_session_path) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-earth-700 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-earth-700 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "rounded border-earth-300 text-forest-600 focus:ring-forest-500" %>
              <%= f.label :remember_me, class: "ml-2 text-sm text-earth-600" %>
            </div>
          <% end %>

          <%= f.submit t("devise_views.sign_in_button"),
              class: "w-full bg-forest-600 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-forest-700 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
