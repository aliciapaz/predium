<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-forest-700">Predium</h1>
      <p class="mt-1 text-sm text-earth-500"><%= t("devise_views.sign_up_subtitle") %></p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
      <%= form_for(resource, as: resource_name, url: user_registration_path) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :first_name, class: "block text-sm font-medium text-earth-700 mb-1" %>
              <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
                  class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
            </div>
            <div>
              <%= f.label :last_name, class: "block text-sm font-medium text-earth-700 mb-1" %>
              <%= f.text_field :last_name, autocomplete: "family-name",
                  class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
            </div>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-earth-700 mb-1" %>
            <%= f.email_field :email, autocomplete: "email",
                class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-earth-700 mb-1" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-earth-400 mb-1"><%= t("devise_views.characters_minimum", count: @minimum_password_length) %></p>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-sm font-medium text-earth-700 mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
          </div>

          <%= f.submit t("devise_views.sign_up_button"),
              class: "w-full bg-forest-600 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-forest-700 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
