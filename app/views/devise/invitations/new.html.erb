<div class="max-w-md mx-auto py-8">
  <h2 class="text-xl font-bold text-earth-800 mb-6"><%= t "devise.invitations.new.header" %></h2>

  <div class="bg-white rounded-lg shadow-sm border border-earth-200 p-6">
    <%= form_for(resource, as: resource_name, url: user_invitation_path, html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <% resource.class.invite_key_fields.each do |field| %>
          <div>
            <%= f.label field, class: "block text-sm font-medium text-earth-700 mb-1" %>
            <%= f.text_field field,
                class: "w-full rounded-md border border-earth-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-forest-500" %>
          </div>
        <% end %>

        <%= f.submit t("devise.invitations.new.submit_button"),
            class: "w-full bg-forest-600 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-forest-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
